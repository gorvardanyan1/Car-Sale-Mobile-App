# Laravel API base URL (no trailing slash) — must end with /api/v1
# Example: http://autohayq/api/v1
# AI support uses /api/ai-support (apiRootUrl strips the trailing /v1 automatically).
EXPO_PUBLIC_API_URL=http://autohayq/api/v1

# Must match MOBILE_APP_SECRET in the car_sale backend's .env — every /api/v1
# request is HMAC-signed with this value (see src/lib/api/signRequest.ts).
EXPO_PUBLIC_MOBILE_APP_SECRET=
